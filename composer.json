{
    "name": "danielakleemann/sweet-blog",
    "description": "A sweet blog application.",
    "license": "MIT",
    "authors": [
        {
            "name": "Daniela Kleemann",
            "email": "dk@webcodingcafe.com"
        }
    ],
    "type": "project",
    "minimum-stability": "stable",
    "autoload": {
        "psr-4": {
            "SweetBlog\\": "src/"
        }
    },
    "autoload-dev": {
