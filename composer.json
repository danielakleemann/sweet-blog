            "Tests\\": "tests/"
        }
    },
    "require": {
        "php": "^8.4",
        "ext-pdo_mysql": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "11.5.0",
        "phpstan/phpstan": "2.0.3",
        "phpstan/phpstan-phpunit": "2.0.1",
        "phpstan/phpstan-strict-rules": "2.0.0"
    }
}
